{
  "expo": {
    "name": "Kinlog",
    "slug": "kinlog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kinlog",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kinlog.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera access is required to analyze your workout movements."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2D2926",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.kinlog.app",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#2D2926"
        }
      ],
      "@react-native-firebase/app",
      [
        "expo-camera",
        {
          "cameraPermission": "Camera access is required to analyze your workout movements."
        }
      ],
      "react-native-vision-camera"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
